PROC SORT DATA=LNNOTE;  BY ACCTNO BONUSANO; RUN;
DATA LNNOTE;
   MERGE LNNOTE(IN=A) OLDNOTE;
   BY ACCTNO BONUSANO;
   IF A;
   IF ISSUEDT GT 0 THEN
      ISSXDTE =INPUT(SUBSTR(PUT(ISSUEDT,Z11.),1,8),MMDDYY8.);

   OLDNOTEDAYARR = 0;
   IF '01APR13'D <= ISSXDTE <= '31JUL15'D AND
      LOANTYPE IN (128,130,131,132,700,705,720,725) AND
      USER5 = 'N' AND
      NOTENO   >= 98010 THEN DO;
         OLDNOTEDAYARR = OLDNOTELASTTRAN - OLDNOTEBLDATE;
         IF OLDNOTEDAYARR < 0 THEN OLDNOTEDAYARR = 0;
   END;

   MO_TAG = MODELDES;
   IF LOANTYPE IN &HP OR
      LOANTYPE IN (15,20,71,72,103,104,107,108) THEN DO;
      IF FIRSILDTE NOT IN (.,0) THEN
         MOSTDTE    = INPUT(SUBSTR(PUT(FIRSILDTE,Z11.),1,8),MMDDYY8.);
      IF CURRILDTE NOT IN (.,0) THEN
         MOENDDTE   = INPUT(SUBSTR(PUT(CURRILDTE,Z11.),1,8),MMDDYY8.);
   END;
   ELSE DO;
      MO_TAG = LMO_TAG;
      IF LMO_MAINT_DT NOT IN (.,0) THEN
         MO_MAIN_DT = INPUT(LMO_MAINT_DT,DDMMYY8.);
      IF LMO_START_DT NOT IN (.,0) THEN
         MOSTDTE    = INPUT(LMO_START_DT,DDMMYY8.);
      IF LMO_END_DT   NOT IN (.,0) THEN
         MOENDDTE   = INPUT(LMO_END_DT,DDMMYY8.);
   END;
RUN;
