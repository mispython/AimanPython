* ******************************************************
* WEEKLY LISTING FOR STAFF NEW LOAN AND PAID LOAN (PIVB)
* ******************************************************;

LIBNAME  LNHIST "SAP.PBB.SGM.SASDATA"  DISP=OLD;
RUN;

OPTIONS YEARCUTOFF=1950 LS=132 PS=60 NOCENTER;

%LET INTGRVAR=(KEEP=LOANTYPE NTBRCH ORGTYPE ACCTNO CURBAL
                    NOTENO NAME APPRLIMT ISSDTE PAIDIND BLDATE
                    BILPAY PAYAMT INTRATE BLDATE STAFFNO PAYEFF
                    ORGBAL LASTTRAN LSTTRNAM LSTTRNCD NOOFAC
                    RESTIND FLAG1 FULRELDTE);

DATA REPTDATE;
   SET MNILN.REPTDATE;
   PREVDATE = MDY(MONTH(REPTDATE),1,YEAR(REPTDATE))-1;
   SELECT(DAY(REPTDATE));
   WHEN (8)  DO; SDD = 1; WK = '01'; END;
   WHEN(15)  DO; SDD = 9; WK = '02'; END;
   WHEN(22)  DO; SDD = 16; WK = '03'; END;
     OTHERWISE DO; SDD = 23; WK = '04'; END;
   END;
   MMP=MONTH(REPTDATE);
   YYP= YEAR(REPTDATE);
   PDATE=MDY(MMP,01,YYP);
   SDATE=MDY(MMP,SDD,YYP);
   CALL SYMPUT('EDATE',PUT(REPTDATE,Z5.));
   CALL SYMPUT('PDATE',PUT(PDATE,Z5.));
   CALL SYMPUT('SDATE',PUT(SDATE,Z5.));
   CALL SYMPUT('NOWK',PUT(WK,$2.));
   CALL SYMPUT('STRDAY',SDD);
   CALL SYMPUT('RDATE',PUT(REPTDATE, DDMMYY10.));
   CALL SYMPUT('REPTMON',PUT(MONTH(REPTDATE),Z2.));
   CALL SYMPUT('REPTDAY',DAY(REPTDATE));
   CALL SYMPUT('REPTMTH',MONTH(REPTDATE));
   CALL SYMPUT('REPTYEAR',YEAR(REPTDATE));
   IF   WK='4' THEN DO;
       CALL SYMPUT('REPTMM',PUT(MONTH(REPTDATE),Z2.));
       CALL SYMPUT('REPTYY',PUT(REPTDATE,YEAR2.));
   END;
   ELSE DO;
       CALL SYMPUT('REPTMM',PUT(MONTH(PREVDATE),Z2.));
       CALL SYMPUT('REPTYY',PUT(PREVDATE,YEAR2.));
   END;
RUN;

PROC SORT DATA=MNILN.LNNOTE OUT=LNNOTE; BY ACCTNO COMMNO;
WHERE LOANTYPE IN (62,70,71,72,73,74,75,76,77,78,106,107,108);
RUN;

PROC SORT DATA=MNILN.LNCOMM OUT=LNCOMM; BY ACCTNO COMMNO;
RUN;

DATA LNNOTE;
     MERGE LNNOTE(IN=A) LNCOMM; BY ACCTNO COMMNO;
     IF A;
     IF COMMNO GT 0 THEN
        IF REVOVLI = 'N' THEN DO;
           APPRLIMT = CORGAMT;
        END;
        ELSE DO;
           APPRLIMT = CCURAMT;
        END;
     ELSE DO;
        APPRLIMT = ORGBAL;
     END;
RUN;

PROC SORT DATA=IMNILN.LNNOTE OUT=ILNNOTE; BY ACCTNO COMMNO;
WHERE LOANTYPE IN (62,70,71,72,73,74,75,76,77,78,106,107,108);
RUN;

PROC SORT DATA=IMNILN.LNCOMM OUT=ILNCOMM; BY ACCTNO COMMNO;
RUN;

DATA ILNNOTE;
     MERGE ILNNOTE(IN=A) ILNCOMM; BY ACCTNO COMMNO;
     IF A;
     IF COMMNO GT 0 THEN
        IF REVOVLI = 'N' THEN DO;
           APPRLIMT = CORGAMT;
        END;
        ELSE DO;
           APPRLIMT = CCURAMT;
        END;
     ELSE DO;
        APPRLIMT = ORGBAL;
     END;
RUN;

DATA LOAN &INTGRVAR;
     SET LNNOTE ILNNOTE;
     LASTTRAN=MDY(INPUT(SUBSTR(PUT(LASTTRAN,Z11.),1,2),2.),
                  INPUT(SUBSTR(PUT(LASTTRAN,Z11.),3,2),2.),
                  INPUT(SUBSTR(PUT(LASTTRAN,Z11.),5,4),4.));
     ISSDTE=MDY(INPUT(SUBSTR(PUT(ISSUEDT,Z11.),1,2),2.),
                INPUT(SUBSTR(PUT(ISSUEDT,Z11.),3,2),2.),
                INPUT(SUBSTR(PUT(ISSUEDT,Z11.),5,4),4.));
     PAYEFF = (INPUT(SUBSTR(PUT(PAYEFFDT,Z11.),10,2),$2.)||'/'||
               INPUT(SUBSTR(PUT(PAYEFFDT,Z11.),8,2),$2.)||'/'||
               INPUT(SUBSTR(PUT(PAYEFFDT,Z11.),3,2),$2.));
     IF FRELEAS NOT IN (.,0) THEN
        FULRELDTE = INPUT(SUBSTR(PUT(FRELEAS,Z11.),1,8),MMDDYY8.);
     NOOFAC = 1;
RUN;

PROC SORT DATA=LOAN OUT=LOAN; BY ACCTNO NOTENO;
RUN;

****************************************************
*** RPT - SETTLED A/C FOR THE WEEK
****************************************************;
DATA LNSETTLE(RENAME=(LASTTRAN=SETTDT LSTTRNAM=SETTAMT
                      LSTTRNCD=SETTCD));
     SET LOAN;
     IF PAIDIND IN ('P','C') AND
        (DAY(LASTTRAN) GE &STRDAY AND DAY(LASTTRAN) LE &REPTDAY
         AND MONTH(LASTTRAN) EQ &REPTMTH
         AND YEAR(LASTTRAN) EQ &REPTYEAR);
     IF LSTTRNCD = 652 THEN
        LSTRNDSC = 'LAST TRANCODE EQ 652';
     ELSE LSTRNDSC = 'LAST TRANCODE NE 652';
RUN;

PROC SORT DATA=LNSETTLE OUT=LNSETTLE; BY LSTRNDSC LOANTYPE NTBRCH;

PROC REPORT DATA=LNSETTLE NOCENTER SPLIT='*' NOWINDOWS HEADSKIP;
     TITLE  'REPORT ID : EIVWSTAF (PIVB)';
     TITLE2 'WEEKLY REPORT FOR STAFF PAID LOAN LIST AS AT '"&RDATE";
     COLUMN LSTRNDSC LOANTYPE NTBRCH ORGTYPE STAFFNO ACCTNO NOTENO
            NAME APPRLIMT SETTDT SETTAMT PAYAMT SETTCD NOOFAC;
     DEFINE LSTRNDSC /GROUP   NOPRINT;
     DEFINE LOANTYPE /GROUP   WIDTH=3 FORMAT=3. 'FAC';
     DEFINE NTBRCH   /GROUP   WIDTH=3 FORMAT=3. 'BRH*CDE';
     DEFINE ORGTYPE  /DISPLAY WIDTH=3 'ORG*TYP';
     DEFINE STAFFNO  /DISPLAY FORMAT=5. 'STAFF*NUM';
     DEFINE ACCTNO   /DISPLAY FORMAT=10.'A/C NO';
     DEFINE NOTENO   /DISPLAY FORMAT=5. 'NOTE*NO';
     DEFINE NAME     /DISPLAY WIDTH=24 'NAME';
     DEFINE APPRLIMT /SUM FORMAT=COMMA14.2    'APPROVED*LIMIT';
     DEFINE SETTDT   /DISPLAY FORMAT=DDMMYY8. 'PAID*DATE';
     DEFINE SETTAMT  /SUM FORMAT=COMMA12.2    'SETTLEMENT*AMOUNT';
     DEFINE PAYAMT   /SUM FORMAT=COMMA12.2    'MONTHLY*REPAYMENT';
     DEFINE SETTCD   /DISPLAY WIDTH=3 'LST*TRN*CDE';
     DEFINE NOOFAC   /SUM NOPRINT;
     BREAK AFTER NTBRCH /SKIP;
     COMPUTE AFTER NTBRCH;
        LINE @008 121*'-';
        LINE @016 'NO OF A/C :'
             @028 NOOFAC.SUM   COMMA8.
             @070 APPRLIMT.SUM COMMA14.2
             @096 SETTAMT.SUM  COMMA12.2
             @110 PAYAMT.SUM   COMMA12.2;
     ENDCOMP;
     BREAK AFTER LOANTYPE /SKIP;
     COMPUTE AFTER LOANTYPE;
        LINE @001 128*'-';
        LINE @001 'FAC TOTAL'
             @016 'NO OF A/C :'
             @028 NOOFAC.SUM   COMMA8.
             @070 APPRLIMT.SUM COMMA14.2
             @096 SETTAMT.SUM  COMMA12.2
             @110 PAYAMT.SUM   COMMA12.2;
        LINE @001 128*'-';
     ENDCOMP;
     BREAK AFTER LSTRNDSC /SKIP;
     COMPUTE AFTER LSTRNDSC;
        LINE @001 128*'=';
        LINE @001 'SUB TOTAL'
             @016 'NO OF A/C :'
             @028 NOOFAC.SUM   COMMA8.
             @070 APPRLIMT.SUM COMMA14.2
             @096 SETTAMT.SUM  COMMA12.2
             @110 PAYAMT.SUM   COMMA12.2;
        LINE @001 128*'=';
     ENDCOMP;
     RBREAK AFTER  /SKIP;
     COMPUTE AFTER;
        LINE @001 'GRAND TOTAL '
             @016 'NO OF A/C : '
             @028 NOOFAC.SUM   COMMA8.
             @070 APPRLIMT.SUM COMMA14.2
             @096 SETTAMT.SUM  COMMA12.2
             @110 PAYAMT.SUM   COMMA12.2;
        LINE @001 128*'=';
     ENDCOMP;
RUN;
PROC SORT DATA=LNHIST.SVBASE OUT=HIST; BY ACCTNO NOTENO;
PROC SORT DATA=LOAN; BY ACCTNO NOTENO;
****************************************************
*** RPT - RELEASE/MIGRATION A/C FOR THE WEEK
****************************************************;
DATA LNRELES
     LNRELS1 (KEEP=ACCTNO NOTENO);
     MERGE LOAN(IN=A) HIST(IN=B); BY ACCTNO NOTENO;
     IF A AND NOT B;
     IF (&PDATE<=FULRELDTE<=&EDATE & FLAG1='M' & RESTIND='M') THEN DO;
        NMN    = 'Y';
        ISSDTE = FULRELDTE;
     END;
     IF (&PDATE <=ISSDTE<= &EDATE) OR NMN = 'Y';
     /*
     IF DAY(ISSDTE) GE &STRDAY AND DAY(ISSDTE) LE &REPTDAY
     IF     MONTH(ISSDTE) EQ &REPTMTH
        AND YEAR(ISSDTE) EQ &REPTYEAR;
     */
     NWI='Y';
RUN;

PROC APPEND DATA=LNRELS1 BASE=LNHIST.SVBASE;

PROC SORT DATA=LNRELES OUT=LNRELES; BY ACCTNO; RUN;
PROC SORT DATA=LNSETTLE OUT=LNSETTLE; BY ACCTNO; RUN;

DATA LNRPT1A LNRPT1B;
     MERGE LNSETTLE(IN=B) LNRELES(IN=A); BY ACCTNO;
     IF (A AND NOT B) THEN DO;
        IF NMN='Y'           THEN OUTPUT LNRPT1B;
        ELSE                      OUTPUT LNRPT1A;
     END;
     IF (A AND B) THEN DO;
        IF NWI='Y'            THEN OUTPUT LNRPT1A;
        IF (ORGBAL = SETTAMT) OR NMN ='Y' THEN OUTPUT LNRPT1B;
     END;
RUN;

DATA LNPAY;
   SET PAY.LNPAY&NOWK IPAY.ILNPAY&NOWK;
   WHERE PAYAMT NE 0;
   PAYEFFDD = 99;
   PAYEFFMM = PUT(MONTH(EFFDATE),Z2.);
   PAYEFFYY = PUT(EFFDATE,YEAR2.);
   PAYEFF   = LEFT(COMPBL(PAYEFFDD||'/'||PAYEFFMM||'/'||PAYEFFYY));
   KEEP ACCTNO NOTENO PAYEFF PAYAMT;
RUN;

PROC SORT DATA=LNPAY; BY ACCTNO NOTENO PAYEFF; RUN;
PROC SORT DATA=LNPAY NODUPKEY; BY ACCTNO NOTENO; RUN;
PROC SORT DATA=LNRPT1B; BY ACCTNO NOTENO; RUN;

DATA LNRPT1B LNRPT1C;
   MERGE LNRPT1B(IN=A) LNPAY;
   BY ACCTNO NOTENO;
   IF A;
   IF NMN = 'Y' THEN OUTPUT LNRPT1C;
   ELSE              OUTPUT LNRPT1B;
RUN;

