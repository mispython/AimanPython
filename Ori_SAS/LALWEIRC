PROC SORT DATA=EIR.EIR&REPTMON&REPTYR OUT=EIR;
   BY ACCTNO NOTENO;
RUN;
DATA EIR;
   MERGE EIR(IN=B) LOAN.LNNOTE(IN=A KEEP=ACCTNO NOTENO PAIDIND
                                         NTINDEX DNBFISME);
   BY ACCTNO NOTENO;
   IF B;
   DNBFI_ORI=DNBFISME;
RUN;
DATA BNM.LOAN&REPTMON&NOWK(DROP=APPREIR);
   MERGE EIR(IN=B RENAME=(APPRLIM2=APPREIR))
         BNM.LOAN&REPTMON&NOWK(IN=A);
   BY ACCTNO NOTENO;
   BAL_AFT_EIR = SUM(BALANCE,EIR_ADJ);
   IF EIR_ADJ NE . & PAIDIND IN ('P','C') THEN BAL_AFT_EIR = EIR_ADJ;
   IF EIR_ADJ NE . AND APPRLIM2 = . THEN APPRLIM2 = APPREIR;
   IF B AND ^A THEN EIRIND = 1;
   IF B AND (A & PAIDIND IN ('P','C')) THEN EIRIND =1;
   IF EIRIND = 1 THEN DO;
      REMAINMH = 0;
      REMMTH   = 0;
      REMAINMT = '51';
   END;

RUN;

DATA BNM.LOAN&REPTMON&NOWK(COMPRESS=YES);
   SET BNM.LOAN&REPTMON&NOWK;

      ORIBAL_AFT_EIR=BAL_AFT_EIR;
      ORIBALANCE=BALANCE;
      ORIBALMNI=BALMNI;

   IF PRODUCT IN (30,31,32,33,34) AND ACCTYPE='OD' THEN DO;
      BAL_AFT_EIR=WRITE_DOWN_BAL;
      BALANCE=WRITE_DOWN_BAL;
      BALMNI=WRITE_DOWN_BAL;
   END;

   IF PRODUCT IN (600:699) AND ACCTYPE='LN' THEN DO;
      BAL_AFT_EIR=WRITE_DOWN_BAL;
      BALANCE=WRITE_DOWN_BAL;
      BALMNI=WRITE_DOWN_BAL;
   END;
RUN;
