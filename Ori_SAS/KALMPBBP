  END;

  IF UTSTY IN ('IFD','ILD','ISD','IZD','IDC','IDP','IZP') AND
     UTREF IN ('PFD','PLD','PSD','PZD','PDC') THEN DO;
     IF MATDT > REPTDATE THEN DO;
        %REMMTH
