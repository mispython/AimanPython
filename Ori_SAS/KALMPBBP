      ELSE IF DCTRNT = 'C' THEN DO;
         IF CUSTCD IN (1)           THEN BNMCODE='6850401000000Y';
         IF CUSTCD IN (2)           THEN BNMCODE='6850402000000Y';
         IF CUSTCD IN (3)           THEN BNMCODE='6850403000000Y';
         IF CUSTCD IN (7)           THEN BNMCODE='6850407000000Y';
         IF CUSTCD IN (12)          THEN BNMCODE='6850412000000Y';
         IF CUSTCD NOT IN (1:3,7,10:12,80:99)
                                    THEN BNMCODE='6850415000000Y';
         IF CUSTCD IN (81:84)       THEN BNMCODE='6850481000000Y';
         IF CUSTCD IN (85:99)       THEN BNMCODE='6850485000000Y';
      END;
      IF DCBCCY = 'JPY' THEN DCIAMT = ROUND(AMOUNT,1.00);
                        ELSE DCIAMT = ROUND(AMOUNT,0.01);
      AMOUNT = DCIAMT * STKRATE;
     END;
    END;
  END;

 END;

  IF BNMCODE NE ' ' THEN OUTPUT;
RUN;

