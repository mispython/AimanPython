   /*******************************************************/
   /*** REPORT 3.. MONTHLY  REPORT FOR LOAN PAID OFF      */
   /***  BY REASONS BY REGIONS BY BRANCH AS AT :          */
   /*******************************************************/

PROC SORT DATA=LOANGRP OUT=REPORT3; BY PAIDOFF GROUP BRH BRANCH;
*;
PROC SUMMARY DATA=REPORT3 NWAY;
CLASS PAIDOFF GROUP BRH BRANCH;
VAR LOANAMT LSTTRNAM;
WHERE PERIOD IN ('THIS MONTH');
OUTPUT OUT=REPORT3M (RENAME=(_FREQ_=NOACCTM) DROP=_TYPE_)
       SUM=AMOUNTM AMOUNTLM;
RUN;
*;
PROC SUMMARY DATA=REPORT3 NWAY;
CLASS PAIDOFF GROUP BRH BRANCH;
VAR LOANAMT LSTTRNAM;
WHERE PERIOD IN ('THIS MONTH','THIS YEAR');
OUTPUT OUT=REPORT3Y (RENAME=(_FREQ_=NOACCTY) DROP=_TYPE_)
       SUM=AMOUNTY AMOUNTLY;
RUN;
*;
DATA REPORT3A;
   MERGE REPORT3M REPORT3Y; BY PAIDOFF GROUP BRH BRANCH;
*;
*;
TITLE1 'REPORT NAME : EIBMLNPO - 3';
PROC REPORT DATA=REPORT3A HEADLINE HEADSKIP NOWD SPLIT='*';
   COLUMN PAIDOFF GROUP BRH BRANCH NOACCTM NOACCTY AMOUNTM AMOUNTY
          AMOUNTLM AMOUNTLY;
   DEFINE PAIDOFF   / GROUP   WIDTH=4     'REA-*SONS';
   DEFINE GROUP     / GROUP   FORMAT=$33. 'REGION';
   DEFINE BRH       / GROUP   WIDTH=6     'BRANCH*ABBR';
   DEFINE BRANCH    / GROUP   FORMAT=6.   'BRANCH*CODE';
   DEFINE NOACCTM   / ANALYSIS SUM FORMAT=COMMA5. 'CURR*MONTH*COUNT';
   DEFINE NOACCTY   / ANALYSIS SUM FORMAT=COMMA5. 'YEAR* TO *DATE*COUNT';
   DEFINE AMOUNTM   / ANALYSIS SUM FORMAT=COMMA13.2
                     'APPROVED LIMT*CURRENT MONTH*(RM)';
   DEFINE AMOUNTY   / ANALYSIS SUM FORMAT=COMMA13.2
                     'APPROVED LIMT*YEAR-TO-DATE*(RM)';
   DEFINE AMOUNTLM  / ANALYSIS SUM FORMAT=COMMA13.2
                     'AMT PAIDOFF*CURRENT MONTH*(RM)';
   DEFINE AMOUNTLY  / ANALYSIS SUM FORMAT=COMMA13.2
                     'AMT PAIDOFF*YEAR-TO-DATE*(RM)';
   BREAK AFTER GROUP /;
   COMPUTE AFTER GROUP;
      LINE @15  118*'-';
      LINE @15 'SUB-TOTAL FOR REGION '
           @60  NOACCTM.SUM COMMA5.     @67  NOACCTY.SUM COMMA5.
           @74  AMOUNTM.SUM COMMA13.2   @89  AMOUNTY.SUM COMMA13.2
           @104 AMOUNTLM.SUM COMMA13.2  @119 AMOUNTLY.SUM COMMA13.2;
      LINE @15  118*'-';
      LINE ' ';
   ENDCOMP;
   BREAK AFTER PAIDOFF /;
   COMPUTE AFTER PAIDOFF;
      IF PAIDOFF IN ('1','01',' 1','1 ')   THEN DO;
              REASONS = 'REFINANCING FROM OFIS';
         END; ELSE
      IF PAIDOFF IN ('2','02',' 2','2 ')   THEN DO;
              REASONS = 'PROPERTY SOLD';
         END; ELSE
      IF PAIDOFF IN ('3','03',' 3','3 ')   THEN DO;
              REASONS = 'FINAL PAYMENT/INSTALMENT';
         END; ELSE
      IF PAIDOFF IN ('4','04',' 4','4 ')   THEN DO;
              REASONS = 'EPF WITHDRAWAL';
         END; ELSE
      IF PAIDOFF IN ('5','05',' 5','5 ')   THEN DO;
          REASONS = 'MIGRATION OF ACCOUNTS UNDER PROGRESIVE RELEASE';
         END; ELSE
      IF PAIDOFF IN ('6','06',' 6','6 ')   THEN DO;
          REASONS = 'PAIDOFF FROM EXCESS FUNDS';
         END; ELSE
      IF PAIDOFF IN ('7','07',' 7','7 ')   THEN DO;
          REASONS = 'REFINANCING FROM BANK RAKYAT';
         END; ELSE
      IF PAIDOFF IN ('8','08',' 8','8 ')   THEN DO;
          REASONS = 'REFINANCING FROM BSN';
         END; ELSE
      IF PAIDOFF IN ('9','09',' 9','9 ')   THEN DO;
          REASONS = 'REFINANCING FROM MBSB';
         END; ELSE
      IF PAIDOFF IN ('10')   THEN DO;
          REASONS = 'REFINANCING FROM BANK ISLAM';
         END; ELSE
      IF PAIDOFF IN ('99')   THEN DO;
              REASONS = 'OTHERS';
         END; ELSE DO;
              REASONS = 'NOT SPECIFIED ??';
         END;
      LINE ' ';
      LINE @08 124*'-';
      LINE @15 'TOTAL ---> ' REASONS  $25.
           @60  NOACCTM.SUM COMMA5.     @67  NOACCTY.SUM COMMA5.
           @74  AMOUNTM.SUM COMMA13.2   @89  AMOUNTY.SUM COMMA13.2
           @104 AMOUNTLM.SUM COMMA13.2  @119 AMOUNTLY.SUM COMMA13.2;
      LINE @08 124*'-';
      LINE  ' ';
   ENDCOMP;
   RBREAK AFTER  /;
   COMPUTE AFTER;
      LINE ' ';
      LINE ' ';
      LINE @12 120*'*';
      LINE @15 'G R A N D  T O T A L --> '
           @60  NOACCTM.SUM COMMA5.     @67  NOACCTY.SUM COMMA5.
           @74  AMOUNTM.SUM COMMA13.2   @89  AMOUNTY.SUM COMMA13.2
           @104 AMOUNTLM.SUM COMMA13.2  @119 AMOUNTLY.SUM COMMA13.2;
      LINE @12 120*'*';
      LINE  ' ';
   ENDCOMP;
   TITLE2 &SDESC;
   TITLE3 'MONTHLY REPORT FOR LOAN PAID OFF';
   TITLE4 'BY REASONS BY REGIONS BY BRANCH AS AT : ' "&RDATE";
RUN;
*;
