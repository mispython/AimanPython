                    'AMOUNT*PAIDOFF (RM)';
   DEFINE PAIDOFF  / DISPLAY  FORMAT=$8. 'REASONS*FOR LOAN*PAIDOFF';
   BREAK AFTER BRH /;
   COMPUTE AFTER BRH;
      LINE ' ';
      LINE @03 108*'-';
