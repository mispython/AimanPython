PROC REPORT DATA=THIMONTH HEADLINE HEADSKIP NOWD SPLIT='*';
   COLUMN BRH BRANCH NAME ACCTNO NOTENO LOANTYPE LOANAMT
          LSTTRNAM PAIDOFF;
   DEFINE BRH      / GROUP   WIDTH=6     'BRANCH*ABBR';
