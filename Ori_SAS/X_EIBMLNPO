      LINE @30 ' 3 = FINAL PAYMENT/INSTALMENT';
      LINE @30 ' 4 = EPF WITHDRAWAL';
      LINE @30 ' 5 = MIGRATION OF ACCOUNTS UNDER PROGRESIVE RELEASE';
      LINE @30 ' 6 = PAIDOFF FROM EXCESS FUNDS';
      LINE @30 ' 7 = REFINANCING FROM BANK RAKYAT';
      LINE @30 ' 8 = REFINANCING FROM BSN';
      LINE @30 ' 9 = REFINANCING FROM MBSB';
      LINE @30 '10 = REFINANCING FROM BANK ISLAM';
      LINE @30 '99 = FOR OTHERS';
      LINE @15 48*'*';
