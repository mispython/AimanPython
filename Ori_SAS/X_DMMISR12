*;
OPTIONS NOCENTER NODATE PAGESIZE=60 LS=134 YEARCUTOFF=1930;

%INC PGM (PBMISFMT);

DATA REPTDATE;
    SET BNM.REPTDATE;
    CALL SYMPUT('REPTMON',PUT(MONTH(REPTDATE),Z2.));
    CALL SYMPUT('REPTYEAR',PUT(REPTDATE,YEAR4.));
    CALL SYMPUT('RDATE',PUT(REPTDATE,DDMMYY10.));
    CALL SYMPUT('ZDATE',PUT(REPTDATE,Z5.));
RUN;

LIBNAME MIS "SAP.PBB.MIS.D&REPTYEAR" DISP=SHR;

TITLE1 'REPORT ID : DMMISR12     REPORT ON WISE ACCOUNTS BY STATE AND AGE RANGE'
                                                   &RDATE;
TITLE2 'PROGRAM ID:';
TITLE3 'BRANCH NO :';
*;
PROC PRINTTO PRINT=COLD1 NEW; RUN;
    /*
TITLE1 'REPORT ID : DMMISR12';
TITLE2 'PUBLIC BANK BERHAD - FINANCIAL PLANNING SERVICES & SUPPORT';
TITLE3 'REPORT ON WISE ACCOUNTS BY STATE AND AGE RANGE';
TITLE4 'AS AT ' &RDATE; */
*;
DATA SDPAGE;
  SET MIS.SDPAGE&REPTMON;
  BRCH=PUT(BRANCH,BRCHCD.);
*;
PROC TABULATE DATA=SDPAGE NOSEPS;
  CLASS STATECD BRANCH BRCH AGE;
  VAR   NOACCT CURBAL;
  WHERE PRODUCT = 212; /* WISE */
  FORMAT STATECD $STATE. AGE AGEDESC.;
  TABLE  STATECD='STATE : ' , (BRANCH=' '*BRCH=' ' ALL),
         AGE*(NOACCT*F=COMMA8. CURBAL*F=COMMA18.2)
         ALL*(NOACCT*F=COMMA8. CURBAL*F=COMMA18.2)
       / RTS=20 MISSTEXT='0' BOX=_PAGE_;
  LABEL  CURBAL = 'BALANCE' NOACCT = 'NO OF A/C';
  KEYLABEL ALL = 'TOTAL' SUM = ' ' N = ' ';
RUN;
*;
PROC PRINTTO; RUN;
*;
TITLE1 'REPORT ID : DMMISR12     REPORT ON YAA ACCOUNTS BY STATE AND AGE RANGE'
       ' AS AT'                                              &RDATE;
TITLE2 'PROGRAM ID:';
TITLE3 'BRANCH NO :';
TITLE4;
*;
PROC PRINTTO PRINT=COLD2 NEW; RUN;
    /*
TITLE2 'PUBLIC BANK BERHAD - FINANCIAL PLANNING SERVICES & SUPPORT';
TITLE3 'REPORT ON YAA ACCOUNTS BY STATE AND AGE RANGE';
TITLE4 'AS AT ' &RDATE; */
*;
PROC TABULATE DATA=MIS.SDPAGE&REPTMON NOSEPS;
  CLASS STATECD BRANCH AGE;
  VAR   NOACCT CURBAL;
  WHERE PRODUCT = 202; /*  YAA PRODUCTS  */
  FORMAT STATECD $STATE.   BRANCH BRCHCD. AGE AGEDESC.;
  TABLE  STATECD='STATE : ', BRANCH ALL,
         AGE*(NOACCT*F=COMMA8. CURBAL*F=COMMA18.2)
         ALL*(NOACCT*F=COMMA8. CURBAL*F=COMMA18.2)
       / RTS=20 MISSTEXT='0' BOX=_PAGE_;
         LABEL CURBAL='BALANCE'  NOACCT='NO OF A/C';
  KEYLABEL ALL='TOTAL'  N=' ' SUM=' ';
RUN;
*;
PROC PRINTTO; RUN;
*;
