OPTIONS YEARCUTOFF=1930 NOCENTER NODATE;

DATA REPTDATE;
  SET MNITB.REPTDATE;
  CALL SYMPUT('REPDD',PUT(DAY(REPTDATE),Z2.));
  CALL SYMPUT('REPMM',PUT(MONTH(REPTDATE),Z2.));
  CALL SYMPUT('REPYY',PUT(REPTDATE,YEAR4.));
  CALL SYMPUT('REPDT',PUT(REPTDATE,DDMMYY8.));
RUN;
*;
DATA DUMMYCA (KEEP=RCOTYP);
    DO I = 1 TO 8;
      DO J = 1 TO 7;
        RCOTYP = 'B'||PUT(J,Z3.)||PUT(I,Z2.);
        OUTPUT;
      END;
      DO K = 1 TO 9;
        RCOTYP = 'C'||PUT(K,Z3.)||PUT(I,Z2.);
        OUTPUT;
      END;
    END;
RUN;
*;
DATA DUMMYSA (KEEP=RCOTYP);
   DO I = 31 TO 42;
      DO J = 1 TO 5;
        RCOTYP = 'B'||PUT(J,Z3.)||PUT(I,Z2.);
        OUTPUT;
      END;
      DO K = 1 TO 8;
        RCOTYP = 'C'||PUT(K,Z3.)||PUT(I,Z2.);
        OUTPUT;
      END;
   END;
RUN;
*;
DATA DUMMYPA (KEEP=RCOTYP);
      DO J = 1;
        RCOTYP = 'P'||PUT(J,Z3.);
        OUTPUT;
      END;
RUN;
*;
PROC SORT DATA=PRODEV.CURRN OUT=RCA; BY RCOTYP CDATE;
DATA RCA;
    SET RCA; BY RCOTYP;
    IF  SUBSTR(CDATE,5,4)="&REPYY";

    IF  FIRST.RCOTYP THEN DO;
        MC=0; YC=0;
    END;
    YC+VC;
    IF  SUBSTR(CDATE,1,2)="&REPMM" THEN DO;
        MC+VC;
    END;
    IF  LAST.RCOTYP THEN OUTPUT;

