CLASS RCOTYP; VAR YC MC;
OUTPUT OUT=RCA (DROP=_FREQ_ _TYPE_) SUM=;
*;
PROC SORT DATA=DUMMYCA; BY RCOTYP;
DATA RCA;
    MERGE DUMMYCA RCA; BY RCOTYP;
*;
DATA RCA;
    SET RCA;
    TYPEX=SUBSTR(RCOTYP,5,2);
    IF TYPEX IN ('01','02','03','04','05','07','08');
    RCODE=SUBSTR(RCOTYP,1,4);
*;
PROC SORT DATA=PRODEV.SAVNG OUT=RSA; BY RCOTYP CDATE;
DATA RSA;
    SET RSA; BY RCOTYP;
    IF  SUBSTR(CDATE,5,4)="&REPYY";

    IF  FIRST.RCOTYP THEN DO;
        MS=0; YS=0;
    END;
    YS+VS;
    IF  SUBSTR(CDATE,1,2)="&REPMM" THEN DO;
        MS+VS;
    END;
    IF  LAST.RCOTYP THEN OUTPUT;

PROC SUMMARY DATA=RSA NWAY;
CLASS RCOTYP; VAR YS MS;
OUTPUT OUT=RSA (DROP=_FREQ_ _TYPE_) SUM=;
*;
PROC SORT DATA=DUMMYPA; BY RCOTYP;
PROC SORT DATA=DUMMYSA; BY RCOTYP;
DATA RSA;
    MERGE DUMMYSA DUMMYPA RSA; BY RCOTYP;
*;
