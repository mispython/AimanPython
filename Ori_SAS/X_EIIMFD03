
OPTIONS YEARCUTOFF=1950 NONUMBER NODATE NOCENTER MISSING=0;
*;
%INC PGM(PBBDPFMT);
*;
DATA _NULL_;
   SET FD.REPTDATE;
   CALL SYMPUT('RDATE',PUT(REPTDATE,DDMMYY8.));
RUN;
*;
DATA FD;
   SET FD.FD;
   IF  OPENIND IN ('O','D');
*;
PROC SORT; BY BRANCH ACCTNO INTPLAN;
*;
DATA FD;
   DROP CURBAL;
   SET FD; BY BRANCH ACCTNO INTPLAN;
   IF  FIRST.INTPLAN THEN CURRBAL=0.00;
   CURRBAL+CURBAL;
   IF LAST.INTPLAN   THEN OUTPUT;
*;
DATA FD1;
   SET FD1.FD;
   IF  OPENIND IN ('O','D');
*;
PROC SORT; BY BRANCH ACCTNO INTPLAN;
*;
DATA FD1;
   DROP CURBAL;
   SET FD1; BY BRANCH ACCTNO INTPLAN;
   IF  FIRST.INTPLAN THEN PREVBAL=0.00;
   PREVBAL+CURBAL;
   IF LAST.INTPLAN   THEN OUTPUT;
*;
DATA FD;
   MERGE FD FD1; BY BRANCH ACCTNO INTPLAN;
   IF PREVBAL=. THEN PREVBAL = 0;
   IF CURRBAL=. THEN CURRBAL = 0;
   MOVEMENT = CURRBAL - PREVBAL;
   IF ABS(MOVEMENT) >= 500000 THEN OUTPUT;
RUN;
PROC SORT DATA=FD; BY ACCTNO; RUN;
*;
DATA CISSAFD(KEEP=ACCTNO CUSTNAME);
   SET CISSAFD.DEPOSIT;
   IF SECCUST = 901;
RUN;
PROC SORT DATA=CISSAFD; BY ACCTNO;RUN;
*;
DATA FD;
   MERGE FD(IN=A) CISSAFD(IN=B); BY ACCTNO;
   IF A;
RUN;
*;
DATA BRHDATA;
  INFILE BRHFILE LRECL=80;
  INPUT @2 BRANCH   3.
        @6 BRABBR  $3.;
RUN;
PROC SORT DATA=BRHDATA; BY BRANCH; RUN;
PROC SORT DATA=FD; BY BRANCH; RUN;
*;
DATA FD;
   MERGE FD(IN=A) BRHDATA(IN=B);
   BY BRANCH;
   IF A;
RUN;
PROC PRINTTO PRINT=FDTEXT NEW;
PROC PRINT DATA=FD LABEL;
   FORMAT PREVBAL CURRBAL MOVEMENT COMMA17.2;
   LABEL PREVBAL = 'PREVIOUS BALANCE'
         CURRBAL = 'CURRENT BALANCE';
   VAR BRANCH BRABBR ACCTNO CUSTNAME INTPLAN CURRBAL PREVBAL MOVEMENT;
   SUM PREVBAL CURRBAL MOVEMENT;
   TITLE1 'PUBLIC ISLAMIC BANK BERHAD';
   TITLE2 'FD MOVEMENT OF RM500,000 AND ABOVE AS AT ' "&RDATE";
   TITLE3 'REPORT ID: EIIMFD03';
RUN;
