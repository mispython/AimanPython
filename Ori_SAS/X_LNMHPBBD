/************************************************/
/** OVERDRAFT AND LOAN POSITION AS AT THE MONTH**/
/************************************************/
PROC DATASETS LIB=MIS NOLIST; DELETE LNPOSN&REPTMON; RUN;

DATA LOANC;
     SET BNM.LOAN&REPTMON&NOWK;

PROC SUMMARY DATA=BNM.LOAN&REPTMON&NOWK NWAY;
CLASS BRANCH ACCTYPE PRODCD PRODUCT CUSTCD;
VAR ACCTNO APPRLIMT BALANCE;
OUTPUT OUT=LNPOSN (DROP=_TYPE_ RENAME=(_FREQ_=NOLOAN))
       N(ACCTNO)=NOACCT
       SUM(APPRLIMT)=APPRLIMT SUM(BALANCE)=BALANCE;
RUN;

PROC APPEND DATA=LNPOSN BASE=MIS.LNPOSN&REPTMON; RUN;
PROC DATASETS LIB=WORK NOLIST; DELETE LNPOSN; RUN;

/************************************************/
/** LOAN BY SECTOR CODE - FOR CREDIT DIVISION  **/
/************************************************/
PROC DATASETS LIB=MIS NOLIST; DELETE LNSECT&REPTMON; RUN;

PROC SUMMARY DATA=LOANC NWAY;
