*;
*;
PROC SORT DATA=LNNAME; BY ACCTNO;
DATA NAME.LNNAME;
   MERGE LNNAME(IN=A) NAME(IN=B); BY ACCTNO;
   IF A AND B;
DATA INAME.LNNAME;
   MERGE LNNAME(IN=A) INAME(IN=B); BY ACCTNO;
   IF A AND B;
RUN;
