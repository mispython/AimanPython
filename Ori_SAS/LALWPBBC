PROC SORT DATA=ALWNOCOM;
   BY ACCTNO APPRLIM2;
*;
DATA APPR1 DUP;
   SET ALWNOCOM;
   BY ACCTNO APPRLIM2;
   IF PRODCD IN ('34190','34690','34170') THEN DO;
      IF FIRST.ACCTNO OR FIRST.APPRLIM2 THEN
      OUTPUT APPR1;
      ELSE DO;
         DUPLI=1;
         OUTPUT DUP;
      END;
   END;
*;
PROC SORT DATA=DUP OUT=DUPLI;
   WHERE BALANCE >= APPRLIM2;
   BY ACCTNO APPRLIM2;
RUN;
DATA APPR1 (KEEP=ACCTNO NOTENO APPRLIM2);
   MERGE ALWNOCOM(IN=A) DUPLI(IN=B KEEP=ACCTNO APPRLIM2 DUPLI);
   BY ACCTNO APPRLIM2;
   IF PRODCD IN ('34190','34690','34170') THEN DO;
      IF DUPLI = 1 THEN DO;
         IF BALANCE >= APPRLIM2 THEN APPRLIM2 = APPRLIM2;
         ELSE APPRLIM2 = 0;
      END;
      ELSE IF FIRST.ACCTNO OR FIRST.APPRLIM2 THEN APPRLIM2 = APPRLIM2;
      ELSE APPRLIM2 = 0;

   END;
   ELSE OUTPUT;
RUN;

