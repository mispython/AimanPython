PROC SORT DATA=LNCOMM; BY ACCTNO COMMNO; RUN;

DATA ABBA(KEEP=ACCTNO NOTENO REBMTD BALANCE RLEASAMT BALMNI);
   MERGE ABBA   (IN=A)
         LNCOMM (IN=B);
   BY ACCTNO COMMNO;
   IF A AND (PRODUCT IN &ABBA);
      REBMTD=INTAMT-INTEARN;

      IF PAIDIND ^='P' THEN DO;
         IF A & B THEN DO;
            BALANCE=(CURBAL-REBMTD)+FEEAMT-CAVAIAMT;
            RLEASAMT=CMHSTADJ;
         END;
         ELSE IF A & ^B THEN DO;
         BALANCE=(CURBAL-REBMTD)+FEEAMT;
         IF PRODUCT ^= 101 AND NTINT = 'A' THEN DO;
         IF (INPUT("&SDATE",DDMMYY8.)<=ISSDTE<=INPUT("&RDATE",DDMMYY8.))
            AND NOT(98000 <= NOTENO <= 99999) THEN RLEASAMT=NETPROC;
         END;
         END;
         IF PRODUCT = 140 THEN BALANCE=(CURBAL-REBMTD)+FEEAMT;
         ELSE IF PRODUCT IN (117,118)
                          THEN BALANCE=(CURBAL+ACCRUAL+FEEAMT);
         ELSE IF PRODUCT = 139 THEN BALANCE=(CURBAL+ACCRUAL+FEEAMT);
         BALMNI = BALANCE;
      END;
      IF SUBSTR(PUT(NOTENO,Z5.),2,1) = '2' THEN RLEASAMT = 0;
RUN;
