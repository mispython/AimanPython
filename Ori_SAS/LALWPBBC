%INC PGM(PBBDPFMT,PBBLNFMT);
%LET ABBA=(110,111,113,115,116,120,127,140,141,142,143);

%MACRO ORIMTH;
   EXYR  =  YEAR(EXPRDATE);
   EXMTH = MONTH(EXPRDATE);
   EXDAY =   DAY(EXPRDATE);
   ISYR  =  YEAR(ISSDTE);
   ISMTH = MONTH(ISSDTE);
   ISDAY =   DAY(ISSDTE);
   ORYY   = EXYR  - ISYR;
   ORMM   = EXMTH - ISMTH;
   ORIMTH = ORYY*12+ORMM;
%MEND ORIMTH;
*;
%MACRO REMMTH;
   MDYR   = YEAR(EXPRDATE);
   MDMTH  =MONTH(EXPRDATE);
   MDDAY  = DAY(EXPRDATE);
   RPYY   = YEAR(REPTDATE);
   RPMM   =MONTH(REPTDATE);
   REMY   = MDYR  - RPYY;
   REMM   = MDMTH - RPMM;
   REMMTH = REMY*12 + REMM;
%MEND REMMTH;
*;
 /***********************************************************/
 /** MANIPULATE THE EXTRACTED LOAN                         **/
 /** (UTILISED ACCOUNT)                                    **/
