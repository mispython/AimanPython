   BY ACCTNO COMMNO;
   IF A;
   IF PRODCD NOT IN ('34190','34690','34170') AND DUPLIAPR = 1 THEN DO;
      UNDRAWN = (BALANCE/BALSUM) * UNDRAWN;
      IF UNDRAWN > 0 THEN APPRLIM2 = SUM(BALANCE,(-1)*FEEAMT,UNDRAWN);
      ELSE APPRLIM2 = (BALANCE/BALSUM) * APPRSUM;
   END;
RUN;
