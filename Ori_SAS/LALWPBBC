PROC SORT DATA=LNCOMM OUT=UCOMM&REPTMON&NOWK;
BY ACCTNO COMMNO;
RUN;

DATA BNM.UNOTE&REPTMON&NOWK;
  LENGTH AMTIND $1.;
  MERGE UNOTE&REPTMON&NOWK (IN=A)
        UCOMM&REPTMON&NOWK (IN=B);
  BY ACCTNO COMMNO;
  IF NOT A AND B;

  ****************************************************
  ** APPLY THE FORMAT                               **
  ****************************************************;
  CUSTCD=PUT(CUSTCODE, LOCUSTCD.);
  AMTIND=PUT(PRODUCT, LNDENOM.);
  SECTORCD=CSECTOR;                 ** CSECTOR  **;
  SECTOR  =CSECTOR;                 ** CSECTOR  **;
  FISSPURP = PUT(CRISPURP,$CRISCD.);
     NEWSEC = SUBSTR(COLLDESC,38,2);
     CENSUS4 = SUBSTR(PUT(CENSUS,7.2),4,1);
  IF FISSPURP = '3100' THEN DO;
     IF NEWSEC = 'N' THEN FISSPURP = '0211';
     ELSE IF CENSUS4 = '1' THEN FISSPURP = '0211';
     ELSE FISSPURP = '0212';
  END;
  IF SECTOLD NE '    ' THEN DO;
     FISSPURP = PUT(SECTOLD,$FISSPUR.);
     IF SECTOLD IN ('0410','0430') AND
        CUSTCD NOT IN ('77','78','95','96') THEN DO;
        IF CUSTCD IN ('61','41','42','43') THEN CUSTCD = '77';
        ELSE IF CUSTCD IN ('62','44','46','47','63','48','49',
                      '51','57','75','59','52','53','54','45',
                      '20','30','32','33','34','35','36',
                      '37','38','39','40') THEN CUSTCD = '78';
     END; /*
     ELSE IF SECTOLD IN ('0211','0212','0220','0230') AND
             CUSTCD NOT IN ('77','78','95','96') THEN
             SECTORCD ='9999';
             */
  END;
     IF '1111'<=SECTOLD<='9999' THEN DO;
     IF PRODUCT IN (128,130,131,132,380,381,700,705,720,725) THEN DO;
        IF LIABCODE = '63' THEN FISSPURP = '0390';
        ELSE IF NEWSEC = 'N' THEN FISSPURP = '0211';
        ELSE IF CENSUS4 = '1' THEN FISSPURP = '0211';
        ELSE FISSPURP = '0212';
     END;
     END;
  *+---------------------------------------------------------------+
   |  LINE BELOW COMMENTED OUT BECAUSE IF CPRODUCT =               |
   |    100, 101 : STAFF LOANS                                     |
   |    120      : CUSTOMER LOANS                                  |
   |  THEREFORE, CPRODUCT DOES NOT INDICATE ACTUAL LOAN PRODUCT.   |
   |  FOR REPORTING PURPOSE, WE ONLY NEED TO KNOW WHETHER UNDRAWN  |
   |    IS FOR TERM LOANS, OD OR OTHERS.                           |
   |  AT COMMITMENT LEVEL, NO INFO ON LOAN PRODUCT. WE ARE MAKING  |
   |    THE ASSUMPTION THAT REVOVLI 'Y' IS RC, OTHER THAN THAT     |
   |    IT IS TERM LOANS NIE                                       |
   +---------------------------------------------------------------+;
  IF REVOVLI = 'Y' THEN DO;
     PRODUCT = 925; PRODCD = '34190';
  END;
  ELSE DO;
     PRODUCT = 999; PRODCD = '34149';
  END;
  IF PRODUCT=139 THEN PRODCD='34190';
  ORIGMT=PUT(CORIGMT, LNORMT.);

  EXPRDATE = INPUT(SUBSTR(PUT(EXPIREDT,Z11.),1,8),MMDDYY8.);

  ****************************************************
  ** LOAN APPROVAL DATE                             **
  ****************************************************;
  APPRDATE=INPUT(SUBSTR(PUT(CAPPDATE, Z11.), 1, 8), MMDDYY8.);

  ****************************************************
  ** THE CURRENT BALANCE = 0                        **
  ****************************************************;
  BALANCE=0;
  BALMNI = BALANCE;

 **********************************************************
 ** COMPUTE THE RELEASE AMOUNT AND THE APPROVED LIMIT    **
 ** THEN CALCULATE THE UNDRAWN PORTION                   **
 **********************************************************;
  IF REVOVLI = 'N' THEN DO;
     RLEASAMT = SUM(CORGAMT, (-1)*CAVAIAMT);
     APPRLIMT = CORGAMT;
  END;
  ELSE DO;
     RLEASAMT = CUSEDAMT;
     APPRLIMT = CCURAMT;
  END;

  UNDRAWN = SUM(APPRLIMT, (-1)*RLEASAMT);
  IF UNDRAWN LT 0 THEN UNDRAWN=0;
RUN;


