PROC SORT DATA=LNCOMM; BY ACCTNO COMMNO; RUN;

DATA BNM.NOTE&REPTMON&NOWK
     ALWNOCOM;
  MERGE BNM.NOTE&REPTMON&NOWK (IN=A)
        LNCOMM (IN=B);
  BY ACCTNO COMMNO;
  IF A;

  ***REVISE BALMNI VIA 2022-3698***;
  IF PAIDIND NE 'P' AND BALMNI < 0 THEN DO;
     IF NTINT = 'S' THEN BALMNI = SUM(CURBAL,FEEAMT,ACCRUAL);
  END;
  **********************************************************
  ** COMPUTE THE RELEASE AMOUNT AND THE APPROVED LIMIT    **
  ** THEN CALCULATE THE UNDRAWN PORTION                   **
  ** APPRLIM2 IS MEANT FOR BIC 8150000000000Y             **
  ** IF PRODCD='34111' - NO HP IN COMMITMENT SEGMENT      **
  **********************************************************;
  APPRLIMT=0; RLEASAMT=0; APPRLIM2=0;
  IF PRODCD='34111' THEN DO;
     APPRLIMT=CURBAL-(REBATE+INTEARN4);
     *** ESMR071184 APPRLIM2=APPRLIMT;
     APPRLIM2=SUM(BALANCE,(-1)*FEEAMT);
     IF (INPUT("&SDATE",DDMMYY8.)<=ISSDTE<=INPUT("&RDATE",DDMMYY8.))
     AND NOT(98000 <= NOTENO <= 99999) THEN RLEASAMT=NETPROC;
  END;
  ELSE DO;
     IF COMMNO GT 0 THEN
        IF PRODCD NOT IN ('34190','34690','34170') THEN DO;
           RLEASAMT = SUM(CORGAMT, (-1)*CAVAIAMT);
           IF RLEASAMT GT CORGAMT THEN RLEASAMT = CORGAMT;
           APPRLIMT = CORGAMT;

           *** ESMR 07-1184;
           IF PRODCD NOT IN ('34180','34190','34690','34170') THEN DO;
              APPRLIM2=SUM(BALANCE,(-1)*FEEAMT,APPRLIMT,(-1)*RLEASAMT);
           END;
           ELSE DO;
              IF PAYFREQ IN (1,2,3,4,6,9) THEN APPRLIM2 = CURBAL;
              ELSE APPRLIM2 = CORGAMT;
              *  RLEASAMT = SUM(CORGAMT, (-1)*CAVAIAMT);
              IF PRODCD IN ('34190','34690','34170') THEN DO;
                 IF FIRST.ACCTNO OR FIRST.COMMNO THEN
                    APPRLIM2 = APPRLIMT;
                 ELSE APPRLIM2 = 0;
              END;
           END;
        END;
        ELSE DO;
           RLEASAMT = CUSEDAMT;
           APPRLIMT = CCURAMT;

           *** ESMR 07-1184;
           IF PRODCD NOT IN ('34180','34190','34690','34170') THEN DO;
              APPRLIM2=SUM(BALANCE,(-1)*FEEAMT,APPRLIMT,(-1)*RLEASAMT);
           END;
           ELSE DO;
              APPRLIM2 = CCURAMT;
              IF PRODCD IN ('34190','34690','34170') THEN DO;
                 IF FIRST.ACCTNO OR FIRST.COMMNO THEN
                    APPRLIM2 = APPRLIMT;
                 ELSE APPRLIM2 = 0;
              END;
           END;
        END;
     ELSE DO;
        RLEASAMT = ORGBAL;
        APPRLIMT = ORGBAL;

        *** ESMR 07-1184;
        IF PRODCD NOT IN ('34180','34190','34690','34170') THEN DO;
           APPRLIM2 = SUM(BALANCE,(-1)*FEEAMT);
        END;
        ELSE DO;
           APPRLIM2 = CURBAL;
           IF PRODCD IN ('34190','34690','34170') THEN DO;
              APPRLIM2 = ORGBAL;
              OUTPUT ALWNOCOM;
           END;
        END;
     END;
  END;
  UNDRAWN = SUM(APPRLIMT, (-1)*RLEASAMT);
  IF PRODCD='34111' THEN DO;
     UNDRAWN=0;
     RLEASAMT = NETPROC;
  END;
  IF UNDRAWN LT 0   THEN UNDRAWN=0;
IF PRODUCT IN (128,130,131,132,380,381,700,705,720,725,752,760)
  THEN DO; APPRLIMT=NETPROC;
END;
  OUTPUT;
RUN;

