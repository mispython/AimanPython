*;
PROC SUMMARY DATA=RDAL2 NWAY;
CLASS BNMCODE AMTIND; VAR AMOUNT;
OUTPUT OUT=RDAL2 (DROP=_TYPE_ _FREQ_) SUM=;
*;
OPTIONS NOCENTER NODATE NONUMBER;
TITLE1 'PUBLIC BANK BERHAD';
