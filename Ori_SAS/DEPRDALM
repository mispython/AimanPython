         BNM.FALW&REPTMON&NOWK;
     IF AMTIND='I';
*;
PROC SUMMARY DATA=RDAL1 NWAY;
CLASS BNMCODE AMTIND; VAR AMOUNT;
OUTPUT OUT=RDAL1 (DROP=_TYPE_ _FREQ_) SUM=;
*;
DATA RDAL2;
     SET BNM.DALM&REPTMON&NOWK
         BNM.FALM&REPTMON&NOWK;
