OPTIONS NOCENTER YEARCUTOFF=1950;
*;
DATA REPTDATE;
   SET DEPOSIT.REPTDATE;
   MM=MONTH(REPTDATE);
   YY= YEAR(REPTDATE);
   STDATE=MDY(MM,1,YY);
   CALL SYMPUT('REPTYEAR',PUT(REPTDATE,YEAR4.));
   CALL SYMPUT('REPTMON',PUT(MONTH(REPTDATE),Z2.));
   CALL SYMPUT('REPTDAY',PUT(DAY(REPTDATE),Z2.));
   CALL SYMPUT('STDATE',PUT(STDATE,Z5.));
RUN;

DATA CURRENT;
   SET BNM.OD&REPTMON;
   IF  REPTDATE GE &STDATE;

PROC SORT; BY REPTDATE PRODCD;


TITLE1 'REPORT ID : EIIFODFR';
TITLE2 'PUBLIC ISLAMIC BANK BERHAD';
TITLE3;
PROC PRINT DATA=CURRENT SPLIT='/';
   BY REPTDATE;
   ID REPTDATE;
   VAR   PRODCD ODTOT ODINDV ODCORP;
   LABEL REPTDATE = 'REPORT DATE'
         PRODCD   = 'PRODUCT/CODE'
         ODTOT    = 'TOTAL OD'
         ODINDV   = 'INDIVIDUALS'
         ODCORP   = 'CORPORATES';

   FORMAT REPTDATE DDMMYY8.
          ODTOT ODINDV ODCORP COMMA18.2;
   WHERE PRODCD IN ('34180','34240');
   TITLE4 'OD BALANCE BY INDIVIDUALS AND CORPORATES';
   TITLE5 'FOR LIQUIDITY FRAMEWORK AS AT: ' &REPTMON '/' &REPTYEAR;
RUN;
