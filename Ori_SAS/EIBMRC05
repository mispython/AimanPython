 /**************************************************************/
 /* USER      : PUBLIC BANK BERHAD, RETAIL CREDIT DIVISION     */
 /* OBJECTIVE : LOANS & ADVANCES BY TYPE OF SECURITY           */
 /* FREQUENCY : MONTHLY                                        */
 /* SELECTION CRITERIA : LIABCODE, ALL LOANS & OD              */
 /**************************************************************/

%INC PGM(EIBMMISF);
OPTION NOCENTER NONUMBER NODATE;
%LET LOAN=(KEEP=BRANCH ACCTNO STATECD PRODUCT SECTORCD COL1
                ACCTYPE LIABCODE APPRLIMT FACTYPE
                BALANCE RLEASAMT UNDRAWN PRODCD);

DATA _NULL_;
   SET BNM.REPTDATE;
   CALL SYMPUT('NOWK',PUT('4',$1.));
   CALL SYMPUT('RDATE',PUT(REPTDATE,DDMMYY10.));
   CALL SYMPUT('REPTMON',PUT(MONTH(REPTDATE),Z2.));
   CALL SYMPUT('RYEAR',PUT(YEAR(REPTDATE),Z4.));
RUN;
DATA LNNOTE;
   SET BNM.LNNOTE;
   KEEP ACCTNO NOTENO LIABCODE;
*;
PROC SORT DATA=LOAN.LOAN&REPTMON&NOWK OUT=SASLOAN;
   BY ACCTNO NOTENO;
*;
DATA LOAN;
   MERGE SASLOAN(IN=A) LNNOTE;
   BY ACCTNO NOTENO;
   IF A;
*;
PROC SORT DATA=LOAN.ULOAN&REPTMON&NOWK OUT=SASULOAN;
   BY ACCTNO COMMNO;
*;
DATA ULOAN;
   MERGE SASULOAN(IN=A) BNM.LNCOMM(KEEP=ACCTNO COMMNO CCOLLTRL) ;
   BY ACCTNO COMMNO;
   IF A;
RUN;
DATA FACIL&REPTMON;
   LENGTH FACTYPE $20.;
   SET LOAN ULOAN;
   IF CCOLLTRL NE . THEN LIABCODE = CCOLLTRL;
   WHERE (SUBSTR(PRODCD, 1, 2) EQ '34' OR PRODCD EQ '54120');
      IF ACCTYPE = 'OD' & PRODCD = '34180' THEN DO;
          LIABCODE = SUBSTR(COL1,1,2);
          FACTYPE = 'OD';
     END;
     ELSE IF ACCTYPE = 'LN' THEN FACTYPE=PUT(PRODCD, $LNFACIL.);
*;
TITLE1 'COLLATERAL CODES UNDER OTHERS CATEGORY';
TITLE2 'FOR VERIFICATION';
*;
PROC SORT; BY LIABCODE FACTYPE BRANCH;
*;

PROC TABULATE DATA=FACIL&REPTMON NOSEPS MISSING;
   FORMAT  LIABCODE $COLLDES.;
   CLASS LIABCODE FACTYPE BRANCH;
   VAR   APPRLIMT BALANCE UNDRAWN;
   TABLE LIABCODE='SECURITY : ' *
         (FACTYPE='FACILITY TYPE'*(BRANCH ALL='SUB-TOTAL') ALL='TOTAL')
         ALL='GRAND TOTAL',
         N*F=COMMA8.
         APPRLIMT*F=COMMA17.2
         BALANCE*F=COMMA17.2
         UNDRAWN*F=COMMA17.2
         /RTS=40;
   KEYLABEL N='NO OF ACCOUNTS'
            SUM=' ';
   LABEL    APPRLIMT='APPROVED LIMIT'
            BALANCE='OUTSTANDING BALANCE';
   TITLE1 'PBB - RETAIL CREDIT DIVISION   ATTN: MS KHOO';
   TITLE2 '005 LOANS & ADVANCES BY TYPE OF SECURITY AS AT ' &RDATE;
RUN;
