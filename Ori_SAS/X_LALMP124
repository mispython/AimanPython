 /**********************************************************/
PROC SORT DATA=LOAN1 OUT=ALM1
(KEEP=ACCTNO NOTENO SECTORCD PRODUCT NOTETERM BALANCE PRODCD CUSTCD
      AMTIND FISSPURP) ;
   BY ACCTNO NOTENO CUSTCD FISSPURP SECTORCD;
   WHERE (SUBSTR(PRODCD,1,3) IN ('341','342','343','344') OR
         PRODUCT IN (225,226)) AND SECTORCD NE '0410';
RUN;
*;
PROC SORT DATA=LOAN&REPTMON&NOWK OUT=ALM
(KEEP=ACCTNO NOTENO SECTORCD PRODUCT NOTETERM EARNTERM BALANCE
      APPRDATE APPRLIM2 PRODCD CUSTCD AMTIND FISSPURP);
   BY ACCTNO NOTENO CUSTCD FISSPURP SECTORCD;
   WHERE (SUBSTR(PRODCD,1,3) IN ('341','342','343','344') OR
        PRODUCT IN (225,226)) AND SECTORCD NE '0410';
RUN;
*;
DATA ALM;
   KEEP SECTORCD DISBURSE REPAID APPRLIM2 ROLLOVER
        AMTIND CUSTCD FISSPURP;
   MERGE ALM1(IN=A RENAME=(BALANCE=LASTBAL NOTETERM=LASTNOTE))
         ALM(IN=B);
   BY ACCTNO NOTENO CUSTCD FISSPURP SECTORCD;

   IF APPRDATE <= INPUT("&RDATE",DDMMYY8.);
   IF APPRDATE < INPUT("&SDATE",DDMMYY8.) THEN APPRLIM2 = 0;
   IF PRODCD IN ('34190') & NOTETERM ^= EARNTERM &
      NOTETERM ^= LASTNOTE THEN ROLLOVER = BALANCE;
   ELSE ROLLOVER = 0;
   DISBURSE = 0; REPAID = 0;
   IF A & B THEN DO;
      IF LASTBAL > BALANCE THEN REPAID = LASTBAL - BALANCE;
      ELSE DISBURSE = BALANCE - LASTBAL;
   END;
   IF ^B THEN REPAID = LASTBAL;
   IF ^A THEN DISBURSE = BALANCE;
*;

DATA UALM;
   KEEP SECTORCD DISBURSE REPAID APPRLIM2 ROLLOVER
        AMTIND CUSTCD FISSPURP;
   RETAIN DISBURSE REPAID ROLLOVER 0;
   SET ULOAN&REPTMON&NOWK;

   IF INPUT("&SDATE",DDMMYY8.) <= APPRDATE <= INPUT("&RDATE",DDMMYY8.);
*;
PROC APPEND BASE=ALM DATA=UALM;
