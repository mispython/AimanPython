PROC SORT DATA=LOAN&REPTMON&NOWK OUT=ALM
(KEEP=ACCTNO NOTENO FISSPURP PRODUCT NOTETERM EARNTERM BALANCE
      APPRDATE APPRLIM2 PRODCD CUSTCD AMTIND SECTORCD);
   BY ACCTNO NOTENO CUSTCD FISSPURP SECTORCD;
   WHERE SUBSTR(PRODCD,1,3) IN ('341','342','343','344') OR
        PRODUCT IN (225,226);
RUN;
