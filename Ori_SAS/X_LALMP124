         END;
         IF CUSTCD IN ('48','49','51') THEN DO;
            BNMCODE=ALMLIMT||'68000000Y'; OUTPUT;
         END;
         IF CUSTCD IN ('52','53','54') THEN DO;
            BNMCODE=ALMLIMT||'69000000Y'; OUTPUT;
