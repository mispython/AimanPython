   IF TODDATE  > 0  THEN TEMPODDT=TODDATE;

   IF (EXODDATE NE 0 OR TEMPODDT NE 0) AND (CURBAL LT 0) THEN DO;
      NODAYS=0;
      IF (EXODDATE = 0 AND TEMPODDT = 0) THEN ODDAYS=0;
      IF (EXODDATE > 0 AND TEMPODDT = 0) THEN DO;
         ODEDATE = INPUT(SUBSTR(PUT(EXODDATE,Z11.),1,8),MMDDYY8.);
         ODDAYS  = MDY(MONTH(ODEDATE),DAY(ODEDATE),YEAR(ODEDATE));
      END;
      IF (EXODDATE = 0 AND TEMPODDT > 0) THEN DO;
         ODTDATE = INPUT(SUBSTR(PUT(TEMPODDT,Z11.),1,8),MMDDYY8.);
         ODDAYS  = MDY(MONTH(ODTDATE),DAY(ODTDATE),YEAR(ODTDATE));
      END;
      IF (EXODDATE > 0 AND TEMPODDT > 0) THEN DO;
         ODEDATE = INPUT(SUBSTR(PUT(EXODDATE,Z11.),1,8),MMDDYY8.);
         ODEDAYS = MDY(MONTH(ODEDATE),DAY(ODEDATE),YEAR(ODEDATE));
         ODTDATE = INPUT(SUBSTR(PUT(TEMPODDT,Z11.),1,8),MMDDYY8.);
         ODTDAYS = MDY(MONTH(ODTDATE),DAY(ODTDATE),YEAR(ODTDATE));
         IF ODEDAYS LE ODTDAYS THEN ODDAYS = ODEDAYS;
                               ELSE ODDAYS = ODTDAYS;
      END;
      IF ODDAYS > 0 THEN NODAYS = &SDATE - ODDAYS;
      IF NODAYS GT 89  THEN TAKEN = 'Y';
   END;
   IF RISKCODE IN ('1','2','3','4') OR CURBAL LT 0 OR
      MTD_DISBURSED_AMT > 0 OR MTD_REPAID_AMT > 0 OR
      PRODUCT IN (30:34) OR (OPENIND IN ('B','C','P'))
      THEN TAKEN = 'Y';
