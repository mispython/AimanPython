   IF PRODCD IN ('34114')               THEN FACILITY = 34351; ELSE
   IF PRODCD IN ('34113')               THEN FACILITY = 34361; ELSE
   IF PRODCD IN ('34230')               THEN FACILITY = 34371; ELSE
   IF PRODCD IN ('34170')               THEN FACILITY = 34460; ELSE
   IF PRODCD IN ('34149','34117','34115')
                                        THEN FACILITY = 34391;
   IF LOANTYPE IN (110,141,200,201,225,
                   227,230,232,237,255,
                   258,259,
                   239,244,246,249,409) THEN FACILITY = 34321; ELSE
   IF LOANTYPE IN (981,984,991,994,410) THEN FACILITY = 34322; ELSE
   IF LOANTYPE IN (993,996,983)         THEN FACILITY = 34331; ELSE
   IF LOANTYPE IN (130,132,381,705,725,
                   679)                 THEN FACILITY = 34332; ELSE
   IF LOANTYPE IN (500,520,982,985,
                   992,995)             THEN FACILITY = 34391; ELSE
   IF LOANTYPE IN (800,801,804,851,852,
                   853,854,855,
                   805,807,809,811,813) THEN FACILITY = 34391; ELSE
   IF LOANTYPE IN (802,803,856,857,858,
                   859,860,817,818,
                   806,808,810,812,814) THEN FACILITY = 34210; ELSE
   IF LOANTYPE IN (102:105)             THEN FACILITY = 34371;

   /* OLD FACILITY
     IF LOANTYPE IN &PRDE                      THEN FACILITY1=34391;
     IF LOANTYPE IN &PRDB & PZIPCODE IN &PRDE  THEN FACILITY1=34391;

     IF LOANTYPE IN &PRDA                      THEN FACILITY1=34210;
     IF LOANTYPE IN &PRDB & PZIPCODE IN &PRDA  THEN FACILITY1=34210;

     IF LOANTYPE IN &PRDC                      THEN FACILITY1=34321;
     IF LOANTYPE IN &PRDB & PZIPCODE IN &PRDC  THEN FACILITY1=34321;
     IF LOANTYPE IN &PRDD                      THEN FACILITY1=34322;
     IF LOANTYPE IN &PRDB & PZIPCODE IN &PRDD  THEN FACILITY1=34322;
     IF LOANTYPE IN (128,131,380,700,720,983,993)
                                               THEN FACILITY1=34331;
     IF LOANTYPE IN (130,132,381,705,725)
                                               THEN FACILITY1=34332;
     IF LOANTYPE IN (390)                      THEN FACILITY1=34341;
     IF LOANTYPE IN (309,310,904,905,919,920)  THEN FACILITY1=34351;
     IF LOANTYPE IN (992) AND
        PZIPCODE IN (309,310,904,905,919,920)  THEN FACILITY1=34351;
     IF LOANTYPE IN (360,908)                  THEN FACILITY1=34361;
     IF LOANTYPE IN &PRDJ                      THEN FACILITY1=34371;
     IF LOANTYPE IN (932,933)                  THEN FACILITY1=34450;
      */

     PURPOSES    = CRISPURP;                       /* LOAN PURPOSE */
     IF PURPOSES = '' THEN PURPOSES = PCODCRIS;    /* ELDS PURPOSE */

     FACCODE = 0;
     FACCODE = PUT(LOANTYPE,FACCODE.);
     IF LOANTYPE IN (600:699) THEN DO;
       IF LOANTYPE IN (678,679) THEN FACCODE=34333;/* SMR 2017-4375 */
       ELSE FACCODE = PUT(FLOOR(CENSUS),FACCODE.);/* SMR 2016 -1165 */
     END;
     IF LOANTYPE IN (128,130,131,132,380,381,700,705,709,710,720,725,
                   750,752,760,983,993,996,678,679) THEN DO;
        PURPOSES = PUT(PURPOSES,$PURPHP.);
        IF      PURPOSES IN ('3100','3101','3110','3120') THEN
           FACCODE = 34333;
        ELSE IF PURPOSES IN ('3300','3900','3901','4100','5100',
                             '5200','3200','3201') THEN
           FACCODE = 34334;
     END;

     IF FACCODE = 0 THEN FACCODE = FACILITY;

     IF B THEN OUTPUT LOAN;
     IF A AND NOT B THEN OUTPUT ELDS;
RUN;

