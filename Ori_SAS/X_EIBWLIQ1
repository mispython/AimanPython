*------------------------------------------------*;
*;
DATA ALW;
     SET BNM1.LOAN&REPTMON&NOWK;
     IF ACCTYPE='OD' AND
        PRODUCT IN (151,152,181) THEN DELETE;
     IF PAIDIND NOT IN ('P','C');
PROC SORT;  BY ACCTNO NOTENO;
