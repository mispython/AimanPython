   END;
   ELSE DO;
      ITEM = 'A1.25';
      IF PRODCD='34240' THEN ITEM = 'A1.28A';
   END;
   RENAME UNDRAWN=AMOUNT;
   IF PRODCD IN ('34600','34690') THEN PART ='2-FC';
   OUTPUT;
